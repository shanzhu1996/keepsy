# Supabase — get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — for AI-generated lesson notes
OPENAI_API_KEY=sk-your-key

# Twilio — for SMS reminders (optional, falls back to manual copy)
TWILIO_ACCOUNT_SID=ACyour-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890

# Resend — for email sending (optional, falls back to manual copy)
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=Keepsy <noreply@yourdomain.com>

# Cron — secret for Vercel cron job authentication (required in production)
CRON_SECRET=your-random-secret
